@model IEnumerable<Clinic_WebAppv2.Models.Patient>

<h2>Patients Management</h2>

<form asp-action="Index" method="get" class="mb-3">
    <input type="text" name="searchPat" class="form-control mb-2" placeholder="Search by Last Name..." />
    <button type="submit" class="btn btn-secondary">Search</button>
</form>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Patient</a>
    <span class="badge bg-primary">Total Patients: @ViewBag.Count</span>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Birth Date</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.patID</td>
                <td>@item.patFName</td>
                <td>@item.patLName</td>
                <td>@item.patBDate.ToShortDateString()</td>
                <td>@item.patTelNo</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.patID" class="btn btn-warning btn-sm">Update</a>
                    <a asp-action="Delete" asp-route-id="@item.patID" class="btn btn-danger btn-sm" onclick="return confirm('Confirm delete?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>