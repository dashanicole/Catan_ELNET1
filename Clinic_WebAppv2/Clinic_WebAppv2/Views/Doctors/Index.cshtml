@model IEnumerable<Clinic_WebAppv2.Models.Doctor>

<h2>Doctors Management</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchName" class="form-control" placeholder="Search by name or specialty..." />
        <button type="submit" class="btn btn-secondary">Search</button>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Doctor</a>
    <span class="badge bg-info text-dark">Total Doctors: @ViewBag.Count</span>
</p>

<table class="table table-striped border">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Specialization</th>
            <th>Address</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.docID</td>
                <td>Dr. @item.docFName @item.docLName</td>
                <td>@item.docSpecial</td>
                <td>@item.docAddress</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.docID" class="btn btn-warning btn-sm">Update</a>
                    <a asp-action="Delete" asp-route-id="@item.docID" class="btn btn-danger btn-sm" onclick="return confirm('Confirm delete?')">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>