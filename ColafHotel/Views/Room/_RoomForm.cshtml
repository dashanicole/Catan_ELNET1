@model RoomFormViewModel

<form asp-action="@(Model.RoomId == 0 ? "Create" : "Edit")" asp-route-id="@Model.RoomId" method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()
    <input asp-for="RoomId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-4">
        <div class="col-md-6">
            <label asp-for="RoomName" class="form-label"></label>
            <input asp-for="RoomName" class="form-control" />
            <span asp-validation-for="RoomName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="RoomType" class="form-label"></label>
            <select asp-for="RoomType" class="form-select">
                <option value="@RoomTypes.Single">Single</option>
                <option value="@RoomTypes.Double">Double</option>
                <option value="@RoomTypes.Suite">Suite</option>
            </select>
            <span asp-validation-for="RoomType" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="PricePerNight" class="form-label"></label>
            <input asp-for="PricePerNight" class="form-control" />
            <span asp-validation-for="PricePerNight" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="ImageFile" class="form-label"></label>
            <input asp-for="ImageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.gif" />
            <span asp-validation-for="ImageFile" class="text-danger"></span>
            @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
            {
                <img src="@Model.ExistingImagePath" alt="Current room image" class="room-form-preview mt-3" />
            }
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Room</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
