@model Room
@{
    ViewData["Title"] = "Room Details";
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="room-image-shell details-image-shell">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="room-image details-image" alt="@Model.RoomName" />
                }
                else
                {
                    <div class="room-image-placeholder details-placeholder">@Model.RoomType</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="h2 mb-0">@Model.RoomName</h1>
                    <span class="badge @(Model.IsAvailable ? "text-bg-success" : "text-bg-secondary")">
                        @(Model.IsAvailable ? "Available" : "Unavailable")
                    </span>
                </div>

                <p class="text-secondary fs-5">@Model.RoomType</p>
                <p class="mb-4">@Model.Description</p>

                <div class="detail-price mb-4">@Model.PricePerNight.ToString("C") <span>/ night</span></div>

                <div class="d-flex flex-wrap gap-2">
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.Guest) && Model.IsAvailable)
                    {
                        <a asp-controller="Reservation" asp-action="Book" asp-route-roomId="@Model.RoomId" class="btn btn-primary">Book This Room</a>
                    }
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.Admin))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.RoomId" class="btn btn-dark">Edit Room</a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to Rooms</a>
                </div>
            </div>
        </div>
    </div>
</div>
