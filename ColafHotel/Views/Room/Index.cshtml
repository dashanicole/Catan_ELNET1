@model RoomIndexViewModel
@{
    ViewData["Title"] = "Rooms";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Browse Rooms</h1>
        <p class="text-secondary mb-0">Search by room name, type, or price range.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.Admin))
    {
        <a asp-action="Create" class="btn btn-primary">Add New Room</a>
    }
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label for="searchTerm" class="form-label">Search</label>
                <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Name or description" />
            </div>
            <div class="col-lg-2">
                <label for="roomType" class="form-label">Type</label>
                <select id="roomType" name="roomType" class="form-select">
                    <option value="">All</option>
                    <option value="@RoomTypes.Single" selected="@(Model.RoomType == RoomTypes.Single)">Single</option>
                    <option value="@RoomTypes.Double" selected="@(Model.RoomType == RoomTypes.Double)">Double</option>
                    <option value="@RoomTypes.Suite" selected="@(Model.RoomType == RoomTypes.Suite)">Suite</option>
                </select>
            </div>
            <div class="col-lg-2">
                <label for="minPrice" class="form-label">Min Price</label>
                <input id="minPrice" name="minPrice" value="@Model.MinPrice" type="number" step="0.01" class="form-control" />
            </div>
            <div class="col-lg-2">
                <label for="maxPrice" class="form-label">Max Price</label>
                <input id="maxPrice" name="maxPrice" value="@Model.MaxPrice" type="number" step="0.01" class="form-control" />
            </div>
            <div class="col-lg-2 d-grid">
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @if (!Model.Rooms.Any())
    {
        <div class="col-12">
            <div class="alert alert-info mb-0">No rooms matched your search.</div>
        </div>
    }

    @foreach (var room in Model.Rooms)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm room-card">
                <div class="room-image-shell">
                    @if (!string.IsNullOrWhiteSpace(room.ImagePath))
                    {
                        <img src="@room.ImagePath" class="card-img-top room-image" alt="@room.RoomName" />
                    }
                    else
                    {
                        <div class="room-image-placeholder">@room.RoomType</div>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h2 class="h5 mb-0">@room.RoomName</h2>
                        <span class="badge @(room.IsAvailable ? "text-bg-success" : "text-bg-secondary")">
                            @(room.IsAvailable ? "Available" : "Unavailable")
                        </span>
                    </div>
                    <p class="text-secondary mb-2">@room.RoomType</p>
                    <p class="text-secondary flex-grow-1">@room.Description</p>
                    <p class="fw-semibold mb-3">@room.PricePerNight.ToString("C") / night</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Details" asp-route-id="@room.RoomId" class="btn btn-outline-primary">Details</a>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.Guest) && room.IsAvailable)
                        {
                            <a asp-controller="Reservation" asp-action="Book" asp-route-roomId="@room.RoomId" class="btn btn-primary">Book Now</a>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(Roles.Admin))
                        {
                            <a asp-action="Edit" asp-route-id="@room.RoomId" class="btn btn-dark">Edit</a>
                            <form asp-action="Delete" asp-route-id="@room.RoomId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete this room?');">Delete</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
