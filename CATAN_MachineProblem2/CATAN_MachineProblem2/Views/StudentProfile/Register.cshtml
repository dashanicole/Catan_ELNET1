@model CATAN_MachineProblem2.Models.StudentProfile

<div class="container">
    <h2>Student Registration</h2>

    <form asp-controller="StudentProfile" asp-action="Register" method="post">
        <div class="form-group">
            <label asp-for="Name">Full Name</label>
            <input asp-for="Name" class="form-control" placeholder="Enter full name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Course">Course</label>
            <input asp-for="Course" class="form-control" placeholder="Enter course (e.g. BSCS)" />
            <span asp-validation-for="Course" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Grade">Final Grade (75-99)</label>
            <input asp-for="Grade" class="form-control" placeholder="75-99" />
            <span asp-validation-for="Grade" class="text-danger"></span>
        </div>

        <div style="margin-top: 30px;">
            <button type="submit" class="btn btn-primary">Save Profile</button>
            <a asp-controller="StudentProfile" asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>

    <partial name="_Footer" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}