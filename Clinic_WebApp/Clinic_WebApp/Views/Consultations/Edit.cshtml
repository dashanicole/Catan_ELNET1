@model Clinic_WebApp.Models.Consultation

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Consultation</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ConsultId" />
            <div class="form-group">
                <label asp-for="PatId" class="control-label"></label>
                <select asp-for="PatId" class="form-control" asp-items="ViewBag.PatId"></select>
                <span asp-validation-for="PatId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DocId" class="control-label"></label>
                <select asp-for="DocId" class="form-control" asp-items="ViewBag.DocId"></select>
                <span asp-validation-for="DocId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConsultDate" class="control-label"></label>
                <input asp-for="ConsultDate" class="form-control" />
                <span asp-validation-for="ConsultDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Diagnosis" class="control-label"></label>
                <input asp-for="Diagnosis" class="form-control" />
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Prescription" class="control-label"></label>
                <input asp-for="Prescription" class="form-control" />
                <span asp-validation-for="Prescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
