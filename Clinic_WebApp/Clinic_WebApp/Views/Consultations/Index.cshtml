@model IEnumerable<Clinic_WebApp.Models.Consultation>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ConsultDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Diagnosis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prescription)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Doc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pat)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ConsultDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Diagnosis)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Doc.DocId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pat.PatId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ConsultId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ConsultId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ConsultId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
