@model IEnumerable<Clinic_WebApp.Models.Doctor>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DocFname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DocLname)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DocAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DocSpecialization)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DocFname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DocLname)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DocAddress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DocSpecialization)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.DocId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.DocId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.DocId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
